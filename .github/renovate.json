{
  "automerge": true,
  "major": {
    "automerge": false
  },
  "platformAutomerge": true,
  "prConcurrentLimit": 5,
  "dependencyDashboard": true,
  "enabledManagers": ["npm", "github-actions"],
  "npm": {
    "minimumReleaseAge": "3 days"
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true
  },
  "extends": [":timezone(Asia/Tokyo)", "packages:eslint", "packages:react"],
  "schedule": ["on the first day of the week"]
}
